rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Logos e fotos de serviços: leitura pública, escrita apenas do dono
    match /establishments/{uid}/logos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /establishments/{uid}/services/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Banners e demais arquivos: apenas o dono acessa
    match /establishments/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
