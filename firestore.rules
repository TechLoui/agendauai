rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /slugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /establishments/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;

      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Appointments: leitura pública necessária para cálculo de slots disponíveis na página de booking
      match /appointments/{appointmentId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null && request.auth.uid == uid;
      }

      // Employees: leitura pública (para seleção no booking), escrita apenas do dono
      match /employees/{employeeId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
